// CodeLess database schema
// Shared by apps/web (writes leads) and apps/admin (reads/updates leads).
// Built to grow: User / Enrollment / Payment are reserved for the future
// paid-course phase and are intentionally not implemented yet.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev; "rhel-openssl-3.0.x" is the Vercel serverless
  // runtime target so the correct query engine ships to production.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: use the pooled URL for `url` and the direct URL for migrations.
  directUrl = env("DIRECT_URL")
}

/// A course-interest lead captured from the public marketing site.
/// No payment is taken at this stage - this is purely a signup of interest.
model Lead {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  name            String
  email           String
  phone           String?
  experienceLevel String? // e.g. none | some | experienced
  source          String? // "how did you hear about us"
  message         String?
  locale          String     @default("ka") // ka | en (site language at submit)

  status          LeadStatus @default(NEW)

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  ARCHIVED
}

/// Admin dashboard operator. Credentials auth (email + bcrypt hash) via Auth.js.
/// Completely separate from any future public `User` accounts.
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

