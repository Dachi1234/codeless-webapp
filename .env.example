# ---- Shared: Neon Postgres (used by both apps via packages/db) ----
# Get this from https://console.neon.tech (use the pooled connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Non-pooled/direct URL for Prisma migrations (Neon "direct connection" string)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---- apps/admin only: Auth.js (NextAuth v5) ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# ---- apps/admin only: first admin user (used by the seed script) ----
ADMIN_EMAIL="admin@codeless.ge"
ADMIN_PASSWORD="change-me-strong-password"
